{
  "providers": {
    "primary": {
      "base_url": "https://api.example.com/v1",
      "api_key_env": "UV_AGENT_PRIMARY_API_KEY",
      "timeout_s": 7200,
      "headers": {},
      "params": {},
      "message_passthrough": {
        "assistant": []
      },
      "reasoning_display": {
        "assistant_message_fields": [],
        "stream_delta_fields": [],
        "unknown_text_delta_as_reasoning": false
      },
      "responses": {
        "path": "/responses",
        "params": {}
      },
      "chat_completions": {
        "path": "/chat/completions",
        "params": {}
      },
      "anthropic_messages": {
        "path": "/messages",
        "params": {}
      }
    }
  },
  "models": {
    "main": {
      "provider": "primary",
      "model": "your-main-model",
      "api": "responses",
      "context_window_tokens": 128000,
      "supports_images": true,
      "params": {
        "reasoning": {
          "effort": "medium"
        }
      }
    },
    "fast": {
      "provider": "primary",
      "model": "your-fast-model",
      "api": "chat_completions",
      "context_window_tokens": 64000,
      "supports_images": false,
      "message_passthrough": {
        "assistant": [
          "reasoning_content"
        ]
      },
      "reasoning_display": {
        "assistant_message_fields": [
          "reasoning_content"
        ],
        "stream_delta_fields": [
          "reasoning_content"
        ],
        "unknown_text_delta_as_reasoning": false
      },
      "params": {
        "temperature": 0.2
      }
    }
  },
  "levels": {
    "small": {
      "model": "fast",
      "params": {}
    },
    "medium": {
      "model": "main",
      "params": {}
    },
    "large": {
      "model": "main",
      "params": {
        "reasoning": {
          "effort": "high"
        }
      }
    }
  },
  "runtime": {
    "default_level": "medium",
    "ask_default_level": "small",
    "store_provider_response": false,
    "max_agent_rounds": 100,
    "compression": {
      "enabled": true,
      "model_level": "small",
      "trigger_ratio": 0.7,
      "min_tokens": 5000,
      "cache_aware": false,
      "margin": 1.5,
      "min_gain": 0.0001,
      "judge_model_level": null,
      "judge_min_context_ratio": 0.20
    },
    "title_generation": {
      "enabled": true,
      "model_level": "small"
    },
    "stream_retry": {
      "max_retries": 5,
      "base": 1.0,
      "factor": 2.0,
      "max": 30.0,
      "jitter": 0.2
    }
  },
  "ui": {
    "language": "auto",
    "completion_notification": {
      "enabled": true,
      "terminal": true,
      "bell": true
    }
  },
  "plugins": {
    "disabled": [],
    "config": {}
  },
  "pricing": {
    "currency": "USD",
    "unit": "1M_tokens",
    "models": {
      "main": {
        "input": 2.0,
        "output": 8.0,
        "cached_input": 0.5
      },
      "fast": {
        "input": 0.5,
        "output": 1.5,
        "cached_input": 0.1
      }
    }
  },
  "runner": {
    "default_timeout_s": 7200,
    "max_output_bytes": 1000000,
    "max_run_logs": 200,
    "scriptenv_index_url": null
  }
}
