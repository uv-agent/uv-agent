{
  "providers": {
    "primary": {
      "base_url": "https://api.example.com/v1",
      "api_key_env": "UV_AGENT_PRIMARY_API_KEY",
      "headers": {},
      "params": {},
      "message_passthrough": {
        "assistant": []
      },
      "reasoning_display": {
        "assistant_message_fields": [],
        "stream_delta_fields": [],
        "unknown_text_delta_as_reasoning": false
      },
      "responses": {
        "path": "/responses",
        "params": {}
      },
      "chat_completions": {
        "path": "/chat/completions",
        "params": {}
      },
      "anthropic_messages": {
        "path": "/messages",
        "params": {}
      }
    }
  },
  "models": {
    "main": {
      "provider": "primary",
      "model": "your-main-model",
      "api": "responses",
      "context_window_tokens": 128000,
      "supports_images": true,
      "params": {
        "reasoning": {
          "effort": "medium"
        }
      }
    },
    "fast": {
      "provider": "primary",
      "model": "your-fast-model",
      "api": "chat_completions",
      "context_window_tokens": 64000,
      "supports_images": false,
      "message_passthrough": {
        "assistant": [
          "reasoning_content"
        ]
      },
      "reasoning_display": {
        "assistant_message_fields": [
          "reasoning_content"
        ],
        "stream_delta_fields": [
          "reasoning_content"
        ],
        "unknown_text_delta_as_reasoning": false
      },
      "params": {
        "temperature": 0.2
      }
    }
  },
  "levels": {
    "small": {
      "model": "fast",
      "params": {}
    },
    "medium": {
      "model": "main",
      "params": {}
    },
    "large": {
      "model": "main",
      "params": {
        "reasoning": {
          "effort": "high"
        }
      }
    }
  },
  "runtime": {
    "default_level": "medium",
    "store_provider_response": false,
    "max_agent_rounds": 100,
    "compression": {
      "enabled": true,
      "model_level": "small",
      "trigger_ratio": 0.7,
      "min_tokens": 5000
    },
    "title_generation": {
      "enabled": true,
      "model_level": "small"
    }
  },
  "ui": {
    "language": "auto"
  },
  "runner": {
    "runtime_dependency": "uv-agent",
    "runtime_package_name": "uv-agent",
    "default_uv_args": [],
    "default_timeout_s": 7200,
    "max_output_bytes": 1000000,
    "max_saved_scripts": 32
  }
}
